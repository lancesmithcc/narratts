# NarraTTS binds to localhost by default. Set 0.0.0.0 for LAN/container access.
TTS_HOST=127.0.0.1
TTS_PORT=8765

# Recommended even for local use. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TTS_API_KEYS=replace-with-a-long-random-key

# Required only for gated/private Hugging Face access.
HF_TOKEN=

# Runtime behavior
TTS_DEFAULT_MODEL=base-1.7b
TTS_WARM_ON_START=true
TTS_LOG_LEVEL=info
TTS_DATA_DIR=~/.narratts
TTS_MAX_TEXT_CHARS=2000
TTS_MAX_REFS=5
TTS_MAX_VOICE_BYTES=50000000
TTS_OUTPUT_TTL=3600

# Comma-separated browser origins allowed to call the API. Empty = same-origin only.
TTS_CORS_ORIGINS=

# Required only when binding beyond localhost with no API key. Unsafe for shared networks.
TTS_ALLOW_UNAUTHENTICATED=false
